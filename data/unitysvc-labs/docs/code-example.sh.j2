#!/bin/bash
# List files in the public dataset
{% if local_testing %}
# Local testing: access public S3 bucket directly
aws s3 ls s3://{{ offering.upstream_access_config["AWS Public S3"].bucket }}/ \
    --no-sign-request \
    --region {{ offering.upstream_access_config["AWS Public S3"].region }} \
    --max-items 10
{% else %}
# Access via UnitySVC S3 gateway
aws --endpoint-url $SERVICE_BASE_URL \
    s3 ls s3://{{ offering.name }}/ \
    --max-items 10
{% endif %}
echo "connectivity ok"
